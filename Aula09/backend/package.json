{
    "name": "aula02",
    "version": "1.0.0",
    "description": "TypeScript + Express starter project",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "dev:container": "ts-node-dev --respawn --transpile-only --poll src/index.ts",
        "dev:docker": "docker compose --profile dev up --build app-dev",
        "dev:docker:down": "docker compose --profile dev down",
        "build": "tsc",
        "start": "node dist/index.js",
        "migrate": "npx prisma migrate dev"
    },
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "@prisma/client": "5.9.1",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "4.21.2",
        "jsonwebtoken": "^9.0.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "4.17.21",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "22.13.10",
        "prisma": "5.9.1",
        "ts-node-dev": "2.0.0",
        "typescript": "5.8.2"
    }
}
