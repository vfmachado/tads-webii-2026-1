{
  "name": "aula02",
  "version": "1.0.0",
  "description": "TypeScript + Express starter project",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:container": "ts-node-dev --respawn --transpile-only --poll src/index.ts",
    "dev:docker": "docker compose --profile dev up --build app-dev",
    "dev:docker:down": "docker compose --profile dev down",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "ejs": "^4.0.1",
    "express": "4.21.2"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "22.13.10",
    "ts-node-dev": "2.0.0",
    "typescript": "5.8.2"
  }
}
