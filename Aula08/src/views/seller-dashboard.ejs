<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MarketMVP | Painel do vendedor</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              display: ["Space Grotesk", "sans-serif"],
              body: ["Plus Jakarta Sans", "sans-serif"],
            },
            colors: {
              brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#43361A", 900: "#251E10" },
              accent: { 500: "#0A7D7A", 600: "#075F5D" },
              coral: { 500: "#E66A4E", 600: "#C85339" },
            },
          },
        },
      };
    </script>
    <style>
      .grid-bg {
        background-image: radial-gradient(#d9ceaa 0.8px, transparent 0.8px), radial-gradient(#d9ceaa 0.8px, #f8f7f2 0.8px);
        background-size: 28px 28px;
        background-position: 0 0, 14px 14px;
      }
    </style>
  </head>
  <body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
          <nav class="hidden gap-5 text-sm font-medium md:flex">
            <a href="/" class="hover:text-accent-600">Início</a>
            <form action="/logout" method="POST">
              <button type="submit" class="hover:text-accent-600">Sair</button>
            </form>
          </nav>
          <a href="#novo-produto" class="rounded-xl bg-coral-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-coral-600">+ Novo anúncio</a>
        </div>
      </header>

      <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <h1 class="font-display text-3xl font-bold">Painel do vendedor</h1>
          <p class="mt-1 text-sm text-brand-700">Gerencie estoque e anúncios publicados com Prisma ORM.</p>
          <div class="mt-5 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl bg-brand-100 p-4"><p class="text-xs font-semibold uppercase tracking-wider">Receita estimada</p><p class="mt-2 font-display text-3xl font-bold">R$ <%= products.reduce((total, product) => total + product.price, 0).toFixed(2).replace('.', ',') %></p></div>
            <div class="rounded-2xl bg-brand-100 p-4"><p class="text-xs font-semibold uppercase tracking-wider">Estoque total</p><p class="mt-2 font-display text-3xl font-bold"><%= products.reduce((total, product) => total + product.stock, 0) %></p></div>
            <div class="rounded-2xl bg-brand-100 p-4"><p class="text-xs font-semibold uppercase tracking-wider">Anúncios ativos</p><p class="mt-2 font-display text-3xl font-bold"><%= products.length %></p></div>
          </div>
        </section>

        <section id="novo-produto" class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <h2 class="font-display text-2xl font-bold">Novo anúncio</h2>
          <p class="mt-1 text-sm text-brand-700">Publique um produto vinculado à sua conta de vendedor. Upload atual: <span class="font-semibold"><%= uploadDriverLabel %></span>.</p>

          <% if (error) { %>
            <p class="mt-4 rounded-xl border border-coral-500/30 bg-coral-500/10 px-4 py-3 text-sm font-semibold text-coral-600"><%= error %></p>
          <% } %>
          <% if (success) { %>
            <p class="mt-4 rounded-xl border border-accent-500/30 bg-accent-500/10 px-4 py-3 text-sm font-semibold text-accent-600"><%= success %></p>
          <% } %>

          <form action="/products" method="POST" enctype="multipart/form-data" class="mt-5 grid gap-4 md:grid-cols-2">
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Nome do produto</span>
              <input name="name" type="text" required class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Categoria</span>
              <select name="category" required class="w-full rounded-xl border border-brand-300 bg-white px-4 py-2.5 outline-none ring-coral-500 focus:ring">
                <option value="">Selecione uma categoria</option>
                <% categoryOptions.forEach(function(category) { %>
                  <option value="<%= category.value %>"><%= category.label %></option>
                <% }) %>
              </select>
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Preço</span>
              <input name="price" type="number" min="0" step="0.01" required class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Estoque</span>
              <input name="stock" type="number" min="0" step="1" required class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <label class="block md:col-span-2">
              <span class="mb-1 block text-sm font-medium">Descrição</span>
              <textarea name="description" rows="4" required class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring"></textarea>
            </label>
            <label class="block md:col-span-2">
              <span class="mb-1 block text-sm font-medium">Foto principal do produto</span>
              <input name="image" type="file" accept="image/png,image/jpeg,image/webp,image/gif" class="w-full rounded-xl border border-brand-300 px-4 py-2.5 text-sm outline-none ring-coral-500 file:mr-4 file:rounded-lg file:border-0 file:bg-brand-100 file:px-3 file:py-2 file:font-semibold file:text-brand-800 hover:file:bg-brand-200 focus:ring" />
              <span class="mt-2 block text-xs text-brand-600">Envie JPG, PNG, WEBP ou GIF com ate 5 MB.</span>
            </label>
            <button type="submit" class="rounded-xl bg-brand-900 px-4 py-2.5 font-semibold text-brand-50 hover:bg-brand-800 md:col-span-2">Publicar produto</button>
          </form>
        </section>

        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <h2 class="font-display text-2xl font-bold">Anúncios atuais</h2>
          </div>
          <div class="mt-4 overflow-x-auto rounded-2xl border border-brand-200">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-brand-100 text-brand-800">
                <tr>
                  <th class="px-4 py-3 font-semibold">Item</th>
                  <th class="px-4 py-3 font-semibold">Categoria</th>
                  <th class="px-4 py-3 font-semibold">Estoque</th>
                  <th class="px-4 py-3 font-semibold">Preço</th>
                  <th class="px-4 py-3 font-semibold">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-brand-200 bg-white">
                <% if (products.length === 0) { %>
                  <tr>
                    <td colspan="5" class="px-4 py-6 text-center text-brand-700">Nenhum anúncio publicado ainda.</td>
                  </tr>
                <% } %>
                <% products.forEach(function(product) { %>
                  <tr>
                    <td class="px-4 py-3">
                      <div class="flex items-center gap-3">
                        <% if (product.imageUrl) { %>
                          <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="h-14 w-14 rounded-xl object-cover" />
                        <% } else { %>
                          <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-brand-100 text-[10px] font-semibold uppercase tracking-wider text-brand-600">Sem foto</div>
                        <% } %>
                        <div>
                          <p class="font-semibold"><%= product.name %></p>
                          <p class="text-xs text-brand-600"><%= product.description %></p>
                          <% if (product.imageStorage) { %>
                            <p class="text-[11px] font-semibold uppercase tracking-wider text-brand-500">Upload: <%= product.imageStorage %></p>
                          <% } %>
                        </div>
                      </div>
                    </td>
                    <td class="px-4 py-3"><%= getProductCategoryLabel(product.category) %></td>
                    <td class="px-4 py-3"><%= product.stock %></td>
                    <td class="px-4 py-3">R$ <%= product.price.toFixed(2).replace('.', ',') %></td>
                    <td class="px-4 py-3">
                      <% if (product.stock > 0) { %>
                        <span class="rounded-full bg-accent-500/10 px-2 py-1 text-xs font-semibold text-accent-600">Ativo</span>
                      <% } else { %>
                        <span class="rounded-full bg-coral-500/10 px-2 py-1 text-xs font-semibold text-coral-600">Sem estoque</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
