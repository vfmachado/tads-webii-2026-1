<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MarketMVP | Início</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              display: ["Space Grotesk", "sans-serif"],
              body: ["Plus Jakarta Sans", "sans-serif"],
            },
            colors: {
              brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#43361A", 900: "#251E10" },
              accent: { 500: "#0A7D7A", 600: "#075F5D" },
              coral: { 500: "#E66A4E", 600: "#C85339" },
            },
          },
        },
      };
    </script>
    <style>
      .grid-bg {
        background-image: radial-gradient(#d9ceaa 0.8px, transparent 0.8px), radial-gradient(#d9ceaa 0.8px, #f8f7f2 0.8px);
        background-size: 28px 28px;
        background-position: 0 0, 14px 14px;
      }
    </style>
  </head>
  <body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="flex items-center gap-3">
            <div class="h-9 w-9 rounded-lg bg-gradient-to-br from-coral-500 to-brand-500"></div>
            <div>
              <p class="font-display text-xl font-bold tracking-tight">MarketMVP</p>
              <p class="text-xs text-brand-700">compre, anuncie e gerencie em um só lugar</p>
            </div>
          </a>
          <nav class="hidden items-center gap-5 text-sm font-medium text-brand-800 md:flex">
            <a href="/" class="hover:text-accent-600">Produtos</a>
            <% if (user && (user.role === 'seller' || user.role === 'admin')) { %>
              <a href="/seller-dashboard" class="hover:text-accent-600">Painel do vendedor</a>
            <% } %>
          </nav>
          <div class="flex items-center gap-2">
            <% if (user) { %>
              <span class="hidden text-sm font-semibold text-brand-700 sm:inline"><%= user.name %> · <%= roleLabel(user.role) %></span>
              <form action="/logout" method="POST">
                <button type="submit" class="rounded-full border border-brand-300 px-4 py-2 text-sm font-semibold hover:bg-brand-100">Sair</button>
              </form>
            <% } else { %>
              <a href="/login" class="rounded-full border border-brand-300 px-4 py-2 text-sm font-semibold hover:bg-brand-100">Entrar</a>
              <a href="/signup" class="rounded-full bg-brand-900 px-4 py-2 text-sm font-semibold text-brand-50 hover:bg-brand-800">Criar conta</a>
            <% } %>
          </div>
        </div>
      </header>

      <main class="mx-auto max-w-7xl space-y-8 px-4 py-8 sm:px-6 lg:px-8">
        <section class="rounded-3xl border border-brand-200 bg-white/85 p-6 shadow-sm md:p-8">
          <div class="grid items-center gap-6 md:grid-cols-2">
            <div>
              <p class="mb-2 inline-flex rounded-full bg-brand-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-700">
                Página inicial com produtos
              </p>
              <h1 class="font-display text-3xl font-bold leading-tight sm:text-4xl">Descubra produtos de vendedores independentes.</h1>
              <p class="mt-4 max-w-xl text-brand-700">Busque por palavras-chave, categorias e anúncios publicados pelos vendedores da plataforma.</p>
              <form action="/" method="GET" class="mt-4 flex gap-2">
                <input
                  name="search"
                  type="text"
                  value="<%= search %>"
                  placeholder="Buscar produtos, marcas e categorias"
                  class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring"
                />
                <button type="submit" class="rounded-xl bg-accent-500 px-5 py-2.5 font-semibold text-white hover:bg-accent-600">Buscar</button>
              </form>
            </div>
            <div class="rounded-2xl bg-gradient-to-br from-brand-100 to-brand-200 p-5">
              <h2 class="font-display text-lg font-bold">Principais categorias</h2>
              <div class="mt-4 grid grid-cols-2 gap-3 text-sm font-semibold">
                <a href="/?search=Eletrônicos" class="rounded-xl bg-white p-3 text-left hover:shadow">Eletrônicos</a>
                <a href="/?search=Casa" class="rounded-xl bg-white p-3 text-left hover:shadow">Casa e decoração</a>
                <a href="/?search=Moda" class="rounded-xl bg-white p-3 text-left hover:shadow">Moda</a>
                <a href="/?search=Esportes" class="rounded-xl bg-white p-3 text-left hover:shadow">Esportes</a>
              </div>
            </div>
          </div>
        </section>

        <section>
          <div class="mb-4 flex items-center justify-between">
            <h2 class="font-display text-2xl font-bold">Produtos em destaque</h2>
            <% if (user && (user.role === 'seller' || user.role === 'admin')) { %>
              <a href="/seller-dashboard" class="text-sm font-semibold text-accent-600 hover:underline">Publicar produto</a>
            <% } %>
          </div>

          <% if (products.length === 0) { %>
            <div class="rounded-2xl border border-brand-200 bg-white p-6 text-brand-700 shadow-sm">
              Nenhum produto encontrado.
            </div>
          <% } else { %>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              <% products.forEach(function(product) { %>
                <article class="rounded-2xl border border-brand-200 bg-white p-4 shadow-sm">
                  <p class="text-xs font-semibold uppercase tracking-wider text-brand-600"><%= product.category %></p>
                  <h3 class="mt-1 font-display text-lg font-bold"><%= product.name %></h3>
                  <p class="mt-1 text-sm text-brand-700"><%= product.description %></p>
                  <p class="mt-2 text-xs font-semibold text-brand-600">Vendedor: <%= product.User.name %></p>
                  <div class="mt-3 flex items-center justify-between">
                    <span class="font-bold text-coral-600">R$ <%= product.price.toFixed(2).replace('.', ',') %></span>
                    <span class="rounded-lg border border-brand-300 px-3 py-1.5 text-sm font-semibold">Estoque: <%= product.stock %></span>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } %>
        </section>
      </main>

      <footer class="mt-8 border-t border-brand-200/80 bg-white/80">
        <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-3 px-4 py-5 text-sm text-brand-700 sm:px-6 lg:px-8">
          <p>Template conceitual para testar o fluxo de um MVP de marketplace.</p>
          <div class="flex gap-4">
            <a href="/" class="hover:text-accent-600">Produtos</a>
            <a href="/seller-dashboard" class="hover:text-accent-600">Vendedor</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
